# Normalize line endings to LF in the repository
* text=auto eol=lf

# Explicitly declare text files
*.cs text eol=lf
*.cshtml text eol=lf
*.json text eol=lf
*.csproj text eol=lf
*.slnx text eol=lf
*.css text eol=lf
*.js text eol=lf
*.html text eol=lf
*.md text eol=lf
*.txt text eol=lf

# Binary files
*.png binary
*.jpg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
