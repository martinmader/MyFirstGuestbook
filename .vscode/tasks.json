{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build",
            "command": "dotnet",
            "type": "process",
            "args": [
                "build",
                "${workspaceFolder}/src/MyFirstGuestbook.Web/MyFirstGuestbook.Web.csproj",
                "/property:GenerateFullPaths=true",
                "/consoleloggerparameters:NoSummary;ForceNoAlign"
            ],
            "problemMatcher": "$msCompile"
        },
        {
            "label": "publish",
            "command": "dotnet",
            "type": "process",
            "args": [
                "publish",
                "${workspaceFolder}/src/MyFirstGuestbook.Web/MyFirstGuestbook.Web.csproj",
                "/property:GenerateFullPaths=true",
                "/consoleloggerparameters:NoSummary;ForceNoAlign"
            ],
            "problemMatcher": "$msCompile"
        },
        {
            "label": "watch",
            "command": "dotnet",
            "type": "process",
            "args": [
                "watch",
                "run",
                "--project",
                "${workspaceFolder}/src/MyFirstGuestbook.Web/MyFirstGuestbook.Web.csproj"
            ],
            "isBackground": true,
            "problemMatcher": {
                "owner": "dotnet-watch",
                "pattern": {
                    "regexp": "^\\s*dotnet watch"
                },
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": "dotnet watch 🔨 Build",
                    "endsPattern": "Now listening on:"
                }
            }
        }
    ]
}